{
  "name": "vawsome",
  "compatibility_date": "2026-07-17",
  "main": "worker.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "routes": [
    { "pattern": "vawsome.com", "custom_domain": true },
    { "pattern": "vinay.vawsome.com", "custom_domain": true }
  ]
}
